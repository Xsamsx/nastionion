---
import Layout from '../layouts/Layout.astro';
import ArchLogo from '../components/ArchLogo.astro';
---

<Layout>
  <!-- Floating Header - Minimalistic -->
  <header class="fixed top-0 left-0 w-full z-50 px-8 py-6 flex justify-between items-center mix-blend-difference pointer-events-none">
    <div class="pointer-events-auto">
      <svg class="w-8 h-10 text-nude hover:text-rose-smoke transition-colors duration-500 cursor-pointer" viewBox="0 0 40 48" xmlns="http://www.w3.org/2000/svg">
        <path d="M4 46 C4 20, 20 4, 20 4 C20 4, 36 20, 36 46" stroke="currentColor" stroke-width="1.5" fill="none"/>
      </svg>
    </div>
    <div class="flex gap-4 pointer-events-auto font-sans text-[10px] tracking-[0.2em] uppercase text-nude">
      <button class="hover:text-rose-smoke transition-colors duration-300 opacity-100 font-medium">EN</button>
      <span class="opacity-20">/</span>
      <button class="hover:text-rose-smoke transition-colors duration-300 opacity-40">UA</button>
    </div>
  </header>

  <!-- Hero - Off Black with Parallax and Organic Shapes -->
  <section class="bg-black-off text-nude min-h-screen min-h-dvh flex items-center relative overflow-x-clip overflow-y-visible" style="background-color: #1B1B1B;">
    <!-- Purple Ambient Glow (extends beyond hero) -->
    <div class="absolute top-[10%] left-[5%] w-[80vw] h-[80vw] rounded-full blur-[200px] pointer-events-none z-0" style="background: radial-gradient(circle, rgba(139,92,246,0.12) 0%, rgba(139,92,246,0) 70%);"></div>
    <div class="absolute bottom-[-20%] right-[10%] w-[60vw] h-[60vw] rounded-full blur-[180px] pointer-events-none z-0" style="background: radial-gradient(circle, rgba(167,139,250,0.1) 0%, transparent 70%);"></div>
    <div class="absolute top-[30%] left-1/2 -translate-x-1/2 w-[90vw] h-[90vw] rounded-full blur-[250px] pointer-events-none z-0" style="background: radial-gradient(circle, rgba(124,58,237,0.06) 0%, transparent 50%);"></div>

    <!-- WebGL Background -->
    <canvas id="hero-3d-canvas" class="absolute inset-0 w-full h-full pointer-events-none" style="background: transparent; z-index: 5;"></canvas>

    <!-- The Portal Arch (Visual Motif) - Extends into next section -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[80vh] opacity-[0.08] pointer-events-none z-10" style="height: 140%;" data-speed="0.85">
      <svg class="w-full h-full text-nude" viewBox="0 0 40 140" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMin slice">
        <path d="M4 140 V46 C4 20, 20 4, 20 4 C20 4, 36 20, 36 46 V140" stroke="currentColor" stroke-width="0.8"/>
        <!-- Inner arches for depth -->
        <path d="M8 140 V46 C8 24, 20 8, 20 8 C20 8, 32 24, 32 46 V140" stroke="currentColor" stroke-width="0.5" opacity="0.6"/>
        <path d="M12 140 V46 C12 28, 20 12, 20 12 C20 12, 28 28, 28 46 V140" stroke="currentColor" stroke-width="0.3" opacity="0.4"/>
      </svg>
    </div>

    <!-- Ethereal Orchid Rings -->
    <div data-speed="0.8" class="absolute top-20 right-20 w-32 h-32 rounded-full border border-soft-orchid/40 float-slow blur-[1px]" style="z-index: 2;">
      <div class="absolute inset-2 rounded-full border border-soft-orchid/20 animate-spin-slow" style="animation-duration: 20s;"></div>
    </div>
    <div data-speed="1.1" class="absolute top-40 right-48 w-16 h-16 rounded-full border border-rose-smoke/30 float-slow" style="z-index: 2; animation-delay: -2s;"></div>
    <div data-speed="1.2" class="absolute bottom-40 left-10 w-24 h-24 rounded-full border border-soft-orchid/30 float-slow blur-[2px]" style="z-index: 2; animation-delay: -3s;"></div>
    <div data-speed="0.9" class="absolute bottom-60 left-32 w-12 h-12 rounded-full border border-nude/20 float-slow" style="z-index: 2; animation-delay: -1s;"></div>
    
    <!-- Spinning sun / text -->
    <div data-speed="0.9" class="absolute top-40 right-36 hidden lg:block opacity-70 z-20">
      <svg class="spin-slow w-48 h-48 text-rose-smoke" viewBox="0 0 200 200">
        <path id="textPath" d="M 100, 100 m -70, 0 a 70,70 0 1,1 140,0 a 70,70 0 1,1 -140,0" fill="none" />
        <text class="text-xs uppercase tracking-widest fill-current font-sans">
          <textPath href="#textPath" startOffset="0%">good vibes · creative energy · social media · </textPath>
        </text>
        <!-- Center star/flower -->
        <path d="M100 75 Q100 100 125 100 Q100 100 100 125 Q100 100 75 100 Q100 100 100 75" fill="currentColor"/>
      </svg>
    </div>

    <div class="max-w-5xl mx-auto px-6 py-16 md:py-24 relative z-20 w-full flex flex-col justify-start mt-10 md:mt-20">
      <div class="opacity-0 animate-fade-up" style="animation-fill-mode: forwards;">
        <div class="mb-10 w-12 h-14 text-rose-smoke overflow-hidden">
           <svg class="w-full h-full" viewBox="0 0 40 48" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 46 C4 20, 20 4, 20 4 C20 4, 36 20, 36 46" stroke="currentColor" stroke-width="2" fill="none"/>
          </svg>
        </div>
        <div data-speed="1.05">
          <h1 class="text-6xl md:text-8xl lg:text-9xl tracking-tight mb-6 font-serif italic text-ivory drop-shadow-sm">Anastasia</h1>
        </div>
        <div data-speed="1.1" class="max-w-2xl">
          <p class="text-rose-smoke text-2xl md:text-3xl mb-6 font-sans font-light">SMM · Targeting · Content Creator</p>
          <p class="text-nude/70 text-lg font-sans font-light leading-relaxed mb-10">
            Elevating lifestyle brands and individuals through aesthetic social media strategy, authentic storytelling, and precise ad campaigns.
          </p>
        </div>
      </div>
    </div>

    <!-- Available for projects - Left side (elevated) -->
    <div class="absolute md:bottom-62 left-0 px-8 md:px-12 flex items-end z-20 font-sans text-[10px] md:text-xs tracking-widest uppercase text-nude/60" style="bottom: calc(7rem + env(safe-area-inset-bottom));">
      <div class="flex flex-col gap-3 pb-2" data-speed="1.02">
        <span class="flex items-center gap-3 text-nude/80">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-smoke opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-rose-smoke shadow-[0_0_15px_rgba(216,167,177,1)]"></span>
          </span>
          Available for projects
        </span>
        <span class="pl-[1.35rem]">Kyiv, Ukraine</span>
      </div>
    </div>

    <!-- Social links - Right side (original position) -->
    <div class="absolute md:bottom-10 right-0 px-8 md:px-12 flex items-end z-20 font-sans text-[10px] md:text-xs tracking-widest uppercase text-nude/60" style="bottom: calc(7rem + env(safe-area-inset-bottom));">
      <div class="flex flex-col gap-3 pb-2 text-right" data-speed="1.02">
        <a href="https://instagram.com/nastion" target="_blank" rel="noopener" class="hover:text-rose-smoke transition-colors duration-300">Instagram</a>
        <a href="https://t.me/nastion" target="_blank" rel="noopener" class="hover:text-rose-smoke transition-colors duration-300">Telegram</a>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 z-20 opacity-70" style="bottom: env(safe-area-inset-bottom);">
      <span class="text-[10px] uppercase tracking-[0.3em] font-sans text-nude/50">Discover</span>
      <div class="w-[1px] h-16 bg-gradient-to-b from-nude/50 to-transparent"></div>
    </div>
  </section>

  <!-- About - Nude with asymmetrical layout -->
  <section class="bg-nude pt-24 pb-20 md:pt-40 md:pb-32 relative overflow-hidden text-black-off">
    <!-- Purple glow bleeding from hero -->
    <div class="absolute -top-[30%] left-[20%] w-[60vw] h-[60vw] rounded-full blur-[200px] pointer-events-none z-0" style="background: radial-gradient(circle, rgba(139,92,246,0.08) 0%, transparent 60%);"></div>
    <div class="absolute -top-[20%] right-[10%] w-[40vw] h-[40vw] rounded-full blur-[150px] pointer-events-none z-0" style="background: radial-gradient(circle, rgba(167,139,250,0.06) 0%, transparent 70%);"></div>

    <!-- Wavy top separator -->
    <div class="absolute top-0 left-0 w-full text-black-off z-10">
      <svg viewBox="0 0 1440 120" class="w-full h-[80px] fill-current" preserveAspectRatio="none">
        <path d="M0,64L80,69.3C160,75,320,85,480,80C640,75,800,53,960,48C1120,43,1280,53,1360,58.7L1440,64L1440,0L1360,0C1280,0,1120,0,960,0C800,0,640,0,480,0C320,0,160,0,80,0L0,0Z"></path>
      </svg>
    </div>

    <!-- Arch continuation through The Vision -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[80vh] h-full opacity-[0.05] pointer-events-none z-20">
      <svg class="w-full h-full text-black-off" viewBox="0 0 40 100" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMin slice">
        <path d="M4 0 V100" stroke="currentColor" stroke-width="0.8"/>
        <path d="M36 0 V100" stroke="currentColor" stroke-width="0.8"/>
        <path d="M8 0 V100" stroke="currentColor" stroke-width="0.5" opacity="0.6"/>
        <path d="M32 0 V100" stroke="currentColor" stroke-width="0.5" opacity="0.6"/>
        <path d="M12 0 V100" stroke="currentColor" stroke-width="0.3" opacity="0.4"/>
        <path d="M28 0 V100" stroke="currentColor" stroke-width="0.3" opacity="0.4"/>
      </svg>
    </div>

    <div class="max-w-5xl mx-auto px-6 relative z-10">
      <div class="grid md:grid-cols-12 gap-8 md:gap-12 items-center">
        <div class="md:col-span-4" data-speed="0.95">
          <p class="text-sm text-burgundy tracking-widest uppercase mb-4 border-b border-burgundy/30 pb-2 inline-block">The Vision</p>
        </div>
        <div class="md:col-span-8 section-fade" style="animation-delay: 0.1s" data-speed="1.05">
          <p class="text-3xl md:text-4xl leading-snug font-serif italic mb-8">
            Creating meaningful digital presence for brands and individuals.
          </p>
          <p class="text-lg md:text-xl text-black-off/70 font-sans font-light leading-relaxed">
            Specializing in social media strategy, targeted advertising,
            and lifestyle content that <span class="text-burgundy font-medium italic">connects</span> deeply with modern audiences. A blend of aesthetics and analytics.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services - Rose Smoke / Burgundy organic cards -->
  <section class="bg-rose-smoke text-black-off py-20 md:py-32 relative">
    <!-- Abstract wavy shape background -->
    <div class="absolute inset-0 opacity-10">
      <svg width="100%" height="100%" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="wavyPattern" x="0" y="0" width="100" height="100" patternUnits="userSpaceOnUse">
            <path d="M0 50 Q 25 25, 50 50 T 100 50" fill="none" stroke="currentColor" stroke-width="1"/>
          </pattern>
        </defs>
        <rect x="0" y="0" width="100%" height="100%" fill="url(#wavyPattern)"/>
      </svg>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="text-center mb-16 md:mb-20">
        <h2 class="text-5xl md:text-6xl font-serif italic text-burgundy">Expertise</h2>
        <div class="w-24 h-[1px] bg-burgundy/30 mx-auto mt-6"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-6 md:gap-8">
        {[
          { id: '01', title: 'SMM', desc: 'Strategy, content planning, and authentic community engagement.', color: 'bg-nude' },
          { id: '02', title: 'Targeting', desc: 'Precise audience mapping and high-conversion ad campaigns.', color: 'bg-burgundy text-nude' },
          { id: '03', title: 'Content', desc: 'Photography, aesthetic reels, and cohesive brand storytelling.', color: 'bg-black-off text-nude' }
        ].map((service, i) => (
          <div class={`service-card p-8 md:p-10 rounded-[2rem] rounded-tl-none ${service.color} transition-all duration-300 shadow-xl shadow-black-off/5 hover:-translate-y-2 hover:shadow-2xl`}>
            <span class="text-sm font-sans tracking-widest opacity-70 mb-8 block">{service.id}</span>
            <h3 class="text-3xl font-serif mb-4">{service.title}</h3>
            <p class="font-sans font-light opacity-90">{service.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Portfolio / Works - Asymmetrical high-end grid -->
  <section class="bg-black-off py-24 md:py-40 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 md:mb-32 gap-8">
        <div data-speed="0.9">
          <h2 class="text-7xl md:text-9xl font-serif italic text-nude leading-none opacity-20 absolute -top-10 -left-4 md:-top-20 md:-left-10 select-none">Selection</h2>
          <h2 class="text-5xl md:text-7xl font-serif italic text-rose-smoke relative z-10">Selected Works</h2>
        </div>
        <p class="text-nude/50 font-sans font-light tracking-widest uppercase text-xs md:text-right max-w-[200px]">
          A curated collection of digital aesthetics and strategic growth.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-12">
        <!-- Work 1: Large Vertical (Photography) -->
        <div class="md:col-span-7 group cursor-pointer" data-speed="1.05">
          <div class="relative overflow-hidden rounded-[2.5rem] bg-burgundy aspect-[4/5] md:aspect-auto md:h-[700px]">
            <div class="absolute inset-0 bg-gradient-to-t from-black-off/80 via-transparent to-transparent opacity-60 group-hover:opacity-40 transition-opacity duration-500"></div>
            <!-- Placeholder for real work -->
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="text-nude/10 text-9xl font-serif italic rotate-12 group-hover:rotate-0 transition-transform duration-700">Aesthetic</span>
            </div>
            <div class="absolute bottom-10 left-10 text-nude transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
              <span class="text-xs tracking-widest uppercase font-sans mb-3 block opacity-70">Photography / Art Direction</span>
              <h3 class="text-4xl md:text-5xl font-serif italic mb-4">The Kinfolk Vision</h3>
              <p class="text-sm font-light opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100 max-w-sm">
                Visual storytelling for a boutique lifestyle brand, focusing on organic textures and natural light.
              </p>
            </div>
          </div>
        </div>

        <!-- Work 2: Small Square (SMM) -->
        <div class="md:col-span-5 flex flex-col gap-12">
          <div class="group cursor-pointer" data-speed="0.95">
            <div class="relative overflow-hidden rounded-[2.5rem] bg-rose-smoke aspect-square">
              <div class="absolute inset-0 bg-gradient-to-t from-burgundy/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <div class="absolute inset-0 flex items-center justify-center">
                <span class="text-burgundy/10 text-7xl font-serif italic -rotate-12 group-hover:rotate-0 transition-transform duration-700">Strategy</span>
              </div>
              <div class="absolute bottom-8 left-8 text-black-off transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                <span class="text-xs tracking-widest uppercase font-sans mb-2 block opacity-70">SMM / Growth</span>
                <h3 class="text-3xl font-serif italic">Moonlight Label</h3>
              </div>
            </div>
          </div>

          <!-- Work 3: Horizontal (Reels) -->
          <div class="group cursor-pointer" data-speed="1.1">
            <div class="relative overflow-hidden rounded-[2.5rem] bg-nude aspect-video">
              <div class="absolute inset-0 bg-gradient-to-t from-black-off/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <div class="absolute inset-0 flex items-center justify-center">
                <span class="text-black-off/10 text-8xl font-serif italic group-hover:scale-110 transition-transform duration-1000">Motion</span>
              </div>
              <div class="absolute bottom-8 left-8 text-black-off transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                <span class="text-xs tracking-widest uppercase font-sans mb-2 block opacity-70">Content / Reels</span>
                <h3 class="text-3xl font-serif italic">Summer Noir Series</h3>
              </div>
              <!-- Play Button Aesthetic -->
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-16 h-16 rounded-full border border-black-off/20 flex items-center justify-center scale-0 group-hover:scale-100 transition-transform duration-500">
                <div class="w-0 h-0 border-t-[8px] border-t-transparent border-l-[12px] border-l-black-off border-b-[8px] border-b-transparent ml-1"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- View More CTA -->
      <div class="mt-20 md:mt-32 text-center" data-speed="0.9">
        <a href="https://instagram.com/nastion" target="_blank" class="group inline-flex items-center gap-4 text-rose-smoke hover:text-nude transition-colors duration-300">
          <span class="text-sm tracking-[0.3em] uppercase font-sans">See All Chronicles</span>
          <div class="w-12 h-[1px] bg-rose-smoke/30 group-hover:w-20 group-hover:bg-nude transition-all duration-500"></div>
        </a>
      </div>
    </div>
  </section>

  <!-- Scrolling Marquee - Burgundy -->
  <section class="bg-burgundy text-nude py-8 overflow-hidden relative z-20">
    <div class="flex">
      <div class="animate-marquee flex shrink-0 items-center space-x-8 text-2xl font-serif italic tracking-wider pr-8">
        <span>CONTENT STRATEGY</span>
        <span class="text-rose-smoke">✦</span>
        <span>BRAND IDENTITY</span>
        <span class="text-rose-smoke">✦</span>
        <span>TARGETED ADS</span>
        <span class="text-rose-smoke">✦</span>
        <span>AESTHETIC REELS</span>
        <span class="text-rose-smoke">✦</span>
        <span>COMMUNITY BUILDING</span>
        <span class="text-rose-smoke">✦</span>
        <span>CONTENT STRATEGY</span>
        <span class="text-rose-smoke">✦</span>
        <span>BRAND IDENTITY</span>
        <span class="text-rose-smoke">✦</span>
        <span>TARGETED ADS</span>
        <span class="text-rose-smoke">✦</span>
        <span>AESTHETIC REELS</span>
        <span class="text-rose-smoke">✦</span>
        <span>COMMUNITY BUILDING</span>
        <span class="text-rose-smoke">✦</span>
      </div>
      <!-- Duplicate for seamless loop -->
      <div class="animate-marquee flex shrink-0 items-center space-x-8 text-2xl font-serif italic tracking-wider pr-8" aria-hidden="true">
        <span>CONTENT STRATEGY</span>
        <span class="text-rose-smoke">✦</span>
        <span>BRAND IDENTITY</span>
        <span class="text-rose-smoke">✦</span>
        <span>TARGETED ADS</span>
        <span class="text-rose-smoke">✦</span>
        <span>AESTHETIC REELS</span>
        <span class="text-rose-smoke">✦</span>
        <span>COMMUNITY BUILDING</span>
        <span class="text-rose-smoke">✦</span>
        <span>CONTENT STRATEGY</span>
        <span class="text-rose-smoke">✦</span>
        <span>BRAND IDENTITY</span>
        <span class="text-rose-smoke">✦</span>
        <span>TARGETED ADS</span>
        <span class="text-rose-smoke">✦</span>
        <span>AESTHETIC REELS</span>
        <span class="text-rose-smoke">✦</span>
        <span>COMMUNITY BUILDING</span>
        <span class="text-rose-smoke">✦</span>
      </div>
    </div>
  </section>

  <!-- Experience - Nude -->
  <section class="bg-nude pt-24 pb-20 md:pt-40 md:pb-32 relative text-black-off">
    <!-- Wavy top separator -->
    <div class="absolute top-0 left-0 w-full text-rose-smoke">
      <svg viewBox="0 0 1440 120" class="w-full h-[80px] fill-current" preserveAspectRatio="none">
        <path d="M0,64L80,74.7C160,85,320,107,480,101.3C640,96,800,64,960,58.7C1120,53,1280,75,1360,85.3L1440,96L1440,0L1360,0C1280,0,1120,0,960,0C800,0,640,0,480,0C320,0,160,0,80,0L0,0Z"></path>
      </svg>
    </div>

    <div class="max-w-4xl mx-auto px-6 relative z-10">
      <div data-speed="0.95" class="mb-16 md:mb-20 text-center">
        <h2 class="text-5xl md:text-6xl font-serif italic text-burgundy">Journey</h2>
      </div>
      
      <div class="space-y-8 pl-4 md:pl-0 border-l border-burgundy/20 md:border-none relative">
        <div data-speed="1.02">
          <div class="relative md:flex gap-12 items-start tilt-card p-6 md:p-8 rounded-[2rem] hover:bg-white/40 transition-all duration-300 border border-transparent hover:border-white/60 shadow-none hover:shadow-xl" style="transform-style: preserve-3d;">
            <div class="hidden md:block w-1/4 text-right pt-2" style="transform: translateZ(20px);">
              <p class="text-sm text-burgundy font-medium tracking-widest">2023 — Present</p>
            </div>
            <div class="absolute -left-[5px] md:static w-3 h-3 rounded-full bg-burgundy mt-2 shrink-0 md:mt-3 shadow-[0_0_0_4px_rgba(75,29,63,0.2)]" style="transform: translateZ(30px);"></div>
            <div class="md:w-3/4 pl-6 md:pl-0" style="transform: translateZ(40px);">
              <p class="text-sm text-burgundy font-medium tracking-widest md:hidden mb-2">2023 — Present</p>
              <h3 class="text-2xl font-serif mb-3">Freelance SMM & Content Creator</h3>
              <p class="text-black-off/70 font-light font-sans">Working with lifestyle brands, personal brands, and small businesses to elevate their digital footprint through organic aesthetics.</p>
            </div>
          </div>
        </div>

        <div data-speed="1.05">
          <div class="relative md:flex gap-12 items-start tilt-card p-6 md:p-8 rounded-[2rem] hover:bg-white/40 transition-all duration-300 border border-transparent hover:border-white/60 shadow-none hover:shadow-xl" style="transform-style: preserve-3d;">
            <div class="hidden md:block w-1/4 text-right pt-2" style="transform: translateZ(20px);">
              <p class="text-sm text-rose-smoke font-medium tracking-widest">2022 — 2023</p>
            </div>
            <div class="absolute -left-[5px] md:static w-3 h-3 rounded-full bg-rose-smoke mt-2 shrink-0 md:mt-3 shadow-[0_0_0_4px_rgba(216,167,177,0.2)]" style="transform: translateZ(30px);"></div>
            <div class="md:w-3/4 pl-6 md:pl-0" style="transform: translateZ(40px);">
              <p class="text-sm text-rose-smoke font-medium tracking-widest md:hidden mb-2">2022 — 2023</p>
              <h3 class="text-2xl font-serif mb-3">Social Media Manager</h3>
              <p class="text-black-off/70 font-light font-sans">Brand collaboration, campaign management, and establishing visual identity for emerging labels.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact - Burgundy with dramatic typography -->
  <section class="bg-burgundy text-nude py-20 md:py-32 relative overflow-hidden">
    <!-- 3D Canvas for contact section -->
    <canvas id="contact-3d-canvas" class="absolute inset-0 w-full h-full pointer-events-none z-0"></canvas>

    <!-- Soft glow backgrounds -->
    <div data-speed="0.8" class="absolute -top-40 -right-40 w-96 h-96 bg-rose-smoke/20 rounded-full blur-3xl"></div>
    <div data-speed="1.2" class="absolute -bottom-20 -left-20 w-80 h-80 bg-black-off/30 rounded-full blur-3xl"></div>

    <!-- Floating rings -->
    <div data-speed="0.9" class="absolute top-16 left-16 w-24 h-24 rounded-full border border-nude/20 float-slow" style="z-index: 2;"></div>
    <div data-speed="1.1" class="absolute top-32 left-28 w-12 h-12 rounded-full border border-rose-smoke/30 float-slow" style="z-index: 2; animation-delay: -2s;"></div>
    <div data-speed="0.85" class="absolute bottom-24 right-20 w-32 h-32 rounded-full border border-soft-orchid/25 float-slow blur-[1px]" style="z-index: 2; animation-delay: -1s;">
      <div class="absolute inset-3 rounded-full border border-nude/15"></div>
    </div>
    <div data-speed="1.15" class="absolute top-20 right-32 w-16 h-16 rounded-full border border-nude/15 float-slow" style="z-index: 2; animation-delay: -3s;"></div>
    <div data-speed="0.95" class="absolute bottom-40 left-1/4 w-8 h-8 rounded-full bg-rose-smoke/10 float-slow blur-sm" style="z-index: 2; animation-delay: -4s;"></div>

    <!-- Small sparkle accents (near text) -->
    <div class="absolute top-1/2 left-1/2 -translate-x-[180px] -translate-y-[80px] w-1.5 h-1.5 bg-nude/50 rounded-full animate-pulse"></div>
    <div class="absolute top-1/2 left-1/2 translate-x-[200px] translate-y-[20px] w-2 h-2 bg-rose-smoke/60 rounded-full animate-pulse" style="animation-delay: -1s;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-[220px] translate-y-[60px] w-1 h-1 bg-nude/40 rounded-full animate-pulse" style="animation-delay: -2s;"></div>

    <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
      <div data-speed="1.05">
        <p class="text-sm text-rose-smoke tracking-widest uppercase mb-6 font-sans">Співпраця</p>
        <h2 class="text-5xl md:text-7xl font-serif italic mb-8">Let's Create Magic</h2>
        <p class="text-nude/80 mb-16 max-w-lg mx-auto font-sans font-light text-lg">
          Open to collaborations, brand partnerships, and new creative projects that push boundaries.
        </p>
        
        <div class="flex flex-wrap justify-center gap-6 font-sans">
          <a href="https://instagram.com/nastion" target="_blank" rel="noopener"
             class="magnetic group relative w-full md:w-auto px-8 py-4 bg-nude text-burgundy rounded-full overflow-hidden block md:inline-block">
            <span class="relative z-10 font-medium tracking-wide">Instagram</span>
            <div class="absolute inset-0 h-full w-full bg-rose-smoke scale-x-0 group-hover:scale-x-100 transition-transform origin-left ease-out duration-300"></div>
          </a>
          <a href="mailto:hello@anastasia.com"
             class="magnetic group relative w-full md:w-auto px-8 py-4 border border-nude/30 rounded-full overflow-hidden block md:inline-block">
             <span class="relative z-10 text-nude group-hover:text-black-off transition-colors duration-300 tracking-wide">Email</span>
             <div class="absolute inset-0 h-full w-full bg-nude scale-x-0 group-hover:scale-x-100 transition-transform origin-left ease-out duration-300"></div>
          </a>
          <a href="https://t.me/nastion" target="_blank" rel="noopener"
             class="magnetic group relative w-full md:w-auto px-8 py-4 border border-nude/30 rounded-full overflow-hidden block md:inline-block">
             <span class="relative z-10 text-nude group-hover:text-black-off transition-colors duration-300 tracking-wide">Telegram</span>
             <div class="absolute inset-0 h-full w-full bg-nude scale-x-0 group-hover:scale-x-100 transition-transform origin-left ease-out duration-300"></div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-black-off text-nude/40 py-10" style="padding-bottom: calc(2.5rem + env(safe-area-inset-bottom));">
    <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center text-sm font-sans gap-4">
      <p class="tracking-widest uppercase text-xs">© 2026 Anastasia. All rights reserved.</p>
      <svg class="w-8 h-10 text-rose-smoke opacity-50" viewBox="0 0 40 48" xmlns="http://www.w3.org/2000/svg">
        <path d="M4 46 C4 20, 20 4, 20 4 C20 4, 36 20, 36 46" stroke="currentColor" stroke-width="1.5" fill="none"/>
      </svg>
      <p class="tracking-widest uppercase text-xs hidden md:block">Designed with Intention</p>
    </div>
  </footer>

  <script>
    import * as THREE from 'three';

    const canvas = document.getElementById('hero-3d-canvas');
    if (canvas) {
      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(90, window.innerWidth / window.innerHeight, 0.1, 1000);
      const renderer = new THREE.WebGLRenderer({ 
        canvas, 
        alpha: true, 
        antialias: true,
        powerPreference: "high-performance" 
      });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
      renderer.setSize(window.innerWidth, window.innerHeight);

      // Camera position
      camera.position.set(-2, 0, 10);

      // Lighting - Maximum intensity for debug
      const ambientLight = new THREE.AmbientLight(0xffffff, 3.0);
      scene.add(ambientLight);
      
      const pointLight = new THREE.PointLight(0xffffff, 50, 100);
      pointLight.position.set(10, 10, 10);
      scene.add(pointLight);

      const objects = [];

      // Reusable Materials
      const matOrchid = new THREE.MeshStandardMaterial({
        color: 0xE5D1D9,
        emissive: 0xE5D1D9,
        emissiveIntensity: 0.4,
        roughness: 0.2,
        metalness: 0.9,
        transparent: true,
        opacity: 0.9
      });
      const matRoseSmoke = new THREE.MeshStandardMaterial({
        color: 0xD8A7B1,
        emissive: 0xD8A7B1,
        emissiveIntensity: 0.4,
        roughness: 0.4,
        metalness: 1.0,
        wireframe: true,
        transparent: true,
        opacity: 0.6
      });
      const matNude = new THREE.MeshStandardMaterial({
        color: 0xE8D9C1,
        roughness: 0.1,
        metalness: 0.3
      });

      // Sculptural Geometries - Ethereal Rings
      const geometries = [
        // 1. Double Orchid Ring
        { geo: new THREE.TorusGeometry(3, 0.05, 16, 100), mat: matOrchid, pos: [6, 2, 0], rot: [0.002, 0.003] },
        // 2. Large Rose Smoke Knot (Reduced opacity wireframe)
        { geo: new THREE.TorusKnotGeometry(3, 0.7, 40, 8, 3, 4), mat: matRoseSmoke, pos: [4, -4, -2], rot: [0.002, 0.004] },
        // 3. Elegant Nude Ring
        { geo: new THREE.TorusGeometry(3.5, 0.4, 12, 48), mat: matNude, pos: [8, 5, -5], rot: [0.005, 0.002] },
        // 4. Nested Orchid Ring
        { geo: new THREE.TorusGeometry(2, 0.03, 16, 80), mat: matOrchid, pos: [12, -2, -3], rot: [0.004, 0.006] },
        // 5. Minimal Nude Ring
        { geo: new THREE.TorusGeometry(1.8, 0.2, 10, 32), mat: matNude, pos: [10, 0, -8], rot: [0.003, 0.005] }
      ];

      geometries.forEach((g, i) => {
        const mesh = new THREE.Mesh(g.geo, g.mat);
        mesh.position.set(g.pos[0], g.pos[1], g.pos[2]);
        scene.add(mesh);
        objects.push({ mesh, rx: g.rot[0], ry: g.rot[1], bx: g.pos[0], by: g.pos[1], offset: i });
      });

      // Mouse interaction
      let mouseX = 0;
      let mouseY = 0;

      const windowHalfX = window.innerWidth / 2;
      const windowHalfY = window.innerHeight / 2;

      document.addEventListener('mousemove', (event) => {
        mouseX = (event.clientX - windowHalfX) * 0.002;
        mouseY = (event.clientY - windowHalfY) * 0.002;
      });

      // Intersection Observer for Hero
      let heroActive = true;
      const heroObs = new IntersectionObserver((entries) => {
        heroActive = entries[0].isIntersecting;
      }, { threshold: 0.1 });
      heroObs.observe(canvas);

      const clock = new THREE.Clock();

      function animate() {
        requestAnimationFrame(animate);
        if (!heroActive) return;

        const elapsedTime = clock.getElapsedTime();
        const targetX = mouseX * 2.5;
        const targetY = mouseY * 2.5;

        // Pulsing glow
        const glow = 0.4 + Math.sin(elapsedTime * 2) * 0.1;
        matOrchid.emissiveIntensity = glow;
        matRoseSmoke.emissiveIntensity = glow * 0.8;

        objects.forEach((obj) => {
          obj.mesh.rotation.x += obj.rx;
          obj.mesh.rotation.y += obj.ry;

          const floatY = Math.sin(elapsedTime * 0.5 + obj.offset) * 0.6;
          const targetPosX = obj.bx + targetX;
          const targetPosY = obj.by - targetY + floatY;

          // Snappier follow (0.08 instead of 0.12 or 0.04)
          obj.mesh.position.x += (targetPosX - obj.mesh.position.x) * 0.08;
          obj.mesh.position.y += (targetPosY - obj.mesh.position.y) * 0.08;
        });

        renderer.render(scene, camera);
      }

      animate();

      window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
      });
    }

    // Contact Section 3D Scene
    const contactCanvas = document.getElementById('contact-3d-canvas');
    if (contactCanvas) {
      const scene2 = new THREE.Scene();
      const camera2 = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
      const renderer2 = new THREE.WebGLRenderer({ canvas: contactCanvas, alpha: true, antialias: true });
      renderer2.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
      renderer2.setSize(window.innerWidth, window.innerHeight);

      const ambientLight2 = new THREE.AmbientLight(0xffffff, 0.8);
      scene2.add(ambientLight2);

      const directionalLight2 = new THREE.DirectionalLight(0xffffff, 1.5);
      directionalLight2.position.set(5, 10, 5);
      scene2.add(directionalLight2);

      // Materials for contact section (Nude/Rose Smoke tones)
      const matNudeContact = new THREE.MeshStandardMaterial({
        color: 0xE8D9C1,
        roughness: 0.2,
        metalness: 0.1,
        transparent: true,
        opacity: 0.6
      });
      const matRoseSmokeContact = new THREE.MeshStandardMaterial({
        color: 0xD8A7B1,
        roughness: 0.3,
        metalness: 0.7,
        wireframe: true,
        transparent: true,
        opacity: 0.4
      });

      const contactObjects = [];

      // Floating nude torus (left) - LOW POLY
      const geoT1 = new THREE.TorusGeometry(1.5, 0.4, 8, 20);
      const meshT1 = new THREE.Mesh(geoT1, matNudeContact);
      meshT1.position.set(-8, 2, -10);
      scene2.add(meshT1);
      contactObjects.push({ mesh: meshT1, rx: 0.005, ry: 0.008, bx: -8, by: 2, offset: 0 });

      // Rose Smoke wireframe knot (right) - LOW POLY
      const geoK1 = new THREE.TorusKnotGeometry(2, 0.5, 24, 6);
      const meshK1 = new THREE.Mesh(geoK1, matRoseSmokeContact);
      meshK1.position.set(9, -1, -12);
      scene2.add(meshK1);
      contactObjects.push({ mesh: meshK1, rx: 0.003, ry: 0.004, bx: 9, by: -1, offset: Math.PI });

      // Small nude icosahedron (top right)
      const geoI1 = new THREE.IcosahedronGeometry(1, 0);
      const meshI1 = new THREE.Mesh(geoI1, matNudeContact);
      meshI1.position.set(7, 4, -8);
      scene2.add(meshI1);
      contactObjects.push({ mesh: meshI1, rx: 0.008, ry: 0.006, bx: 7, by: 4, offset: 2 });

      // Rose Smoke ring (bottom left) - LOW POLY
      const geoR1 = new THREE.TorusGeometry(2, 0.3, 8, 20);
      const meshR1 = new THREE.Mesh(geoR1, matRoseSmokeContact);
      meshR1.position.set(-6, -3, -14);
      scene2.add(meshR1);
      contactObjects.push({ mesh: meshR1, rx: 0.004, ry: 0.007, bx: -6, by: -3, offset: 1.5 });

      camera2.position.z = 5;

      const clock2 = new THREE.Clock();

      // Intersection Observer for Contact
      let contactActive = false;
      const contactObs = new IntersectionObserver((entries) => {
        contactActive = entries[0].isIntersecting;
      }, { threshold: 0.1 });
      contactObs.observe(contactCanvas);

      function animateContact() {
        requestAnimationFrame(animateContact);
        if (!contactActive) return;

        const elapsedTime = clock2.getElapsedTime();

        contactObjects.forEach(obj => {
          obj.mesh.rotation.x += obj.rx;
          obj.mesh.rotation.y += obj.ry;
          const floatY = Math.sin(elapsedTime * 0.4 + obj.offset) * 0.3;
          obj.mesh.position.y = obj.by + floatY;
        });

        renderer2.render(scene2, camera2);
      }

      animateContact();

      window.addEventListener('resize', () => {
        camera2.aspect = window.innerWidth / window.innerHeight;
        camera2.updateProjectionMatrix();
        renderer2.setSize(window.innerWidth, window.innerHeight);
      });
    }

    // Tilt effect for service cards (desktop only)
    const isMobile = window.matchMedia("(max-width: 768px)").matches;
    if (!isMobile) {
      const tiltCards = document.querySelectorAll('[data-tilt]');
      tiltCards.forEach(card => {
        let currentX = 0;
        let currentY = 0;
        let targetX = 0;
        let targetY = 0;

        card.addEventListener('mouseenter', () => {
          card.style.transition = 'none';
        });

        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          const centerX = rect.width / 2;
          const centerY = rect.height / 2;
          targetX = (y - centerY) / 15;
          targetY = (centerX - x) / 15;

          currentX += (targetX - currentX) * 0.1;
          currentY += (targetY - currentY) * 0.1;

          card.style.transform = `perspective(1000px) rotateX(${currentX}deg) rotateY(${currentY}deg) scale(1.02)`;
        });

        card.addEventListener('mouseleave', () => {
          card.style.transition = 'transform 0.5s ease-out';
          card.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) scale(1)';
        });
      });
    }
  </script>
</Layout>
