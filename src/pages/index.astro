---
import Layout from '../layouts/Layout.astro';
import ArchLogo from '../components/ArchLogo.astro';
---

<Layout>
  <!-- Hero - Forest Green with Parallax and Organic Shapes -->
  <section class="bg-forest text-cream min-h-screen flex items-center relative overflow-hidden pt-[env(safe-area-inset-top)] pb-[env(safe-area-inset-bottom)]" style="background-color: #1E3A2F;">
    <!-- WebGL Background (z-0) -->
    <canvas id="hero-3d-canvas" class="absolute inset-0 w-full h-full pointer-events-none z-0" style="background: transparent;"></canvas>

    <!-- Abstract wavy shapes -->
    <div data-speed="0.8" class="absolute top-10 right-10 w-[400px] h-[400px] bg-sage/20 wavy-border float-slow blur-2xl"></div>
    <div data-speed="1.2" class="absolute bottom-32 -left-20 w-[400px] h-[400px] bg-terracotta/20 wavy-border float-slow blur-3xl" style="animation-delay: -3s;"></div>
    
    <!-- Spinning sun / text -->
    <div data-speed="0.9" class="absolute top-30 right-36 hidden lg:block opacity-70 z-20">
      <svg class="spin-slow w-48 h-48 text-sunflower" viewBox="0 0 200 200">
        <path id="textPath" d="M 100, 100 m -70, 0 a 70,70 0 1,1 140,0 a 70,70 0 1,1 -140,0" fill="none" />
        <text class="text-xs uppercase tracking-widest fill-current font-sans">
          <textPath href="#textPath" startOffset="0%">good vibes · creative energy · social media · </textPath>
        </text>
        <!-- Center star/flower -->
        <path d="M100 75 Q100 100 125 100 Q100 100 100 125 Q100 100 75 100 Q100 100 100 75" fill="currentColor"/>
      </svg>
    </div>

    <div class="max-w-5xl mx-auto px-6 py-16 md:py-24 relative z-20 w-full flex flex-col justify-start mt-10 md:mt-20">
      <div class="opacity-0 animate-fade-up" style="animation-fill-mode: forwards;">
        <svg class="mb-10 w-12 h-14 text-sunflower" viewBox="0 0 40 48" xmlns="http://www.w3.org/2000/svg">
          <path d="M4 46 C4 20, 20 4, 20 4 C20 4, 36 20, 36 46" stroke="currentColor" stroke-width="2" fill="none"/>
        </svg>
        <div data-speed="1.05">
          <h1 class="text-6xl md:text-8xl lg:text-9xl tracking-tight mb-6 font-serif italic text-ivory drop-shadow-sm">Anastasia</h1>
        </div>
        <div data-speed="1.1" class="max-w-2xl">
          <p class="text-sage text-2xl md:text-3xl mb-6 font-sans font-light">SMM · Targeting · Content Creator</p>
          <p class="text-cream/70 text-lg font-sans font-light leading-relaxed mb-10">
            Elevating lifestyle brands and individuals through aesthetic social media strategy, authentic storytelling, and precise ad campaigns.
          </p>
        </div>
      </div>
    </div>

    <!-- Available for projects - Left side (elevated) -->
    <div class="absolute bottom-12 md:bottom-62 left-0 px-8 md:px-12 flex items-end z-20 font-sans text-[10px] md:text-xs tracking-widest uppercase text-cream/60">
      <div class="flex flex-col gap-3 pb-2" data-speed="1.02">
        <span class="flex items-center gap-3 text-cream/80">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-sunflower opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-sunflower shadow-[0_0_15px_rgba(225,169,95,1)]"></span>
          </span>
          Available for projects
        </span>
        <span class="pl-[1.35rem]">Kyiv, Ukraine</span>
      </div>
    </div>

    <!-- Social links - Right side (original position) -->
    <div class="absolute bottom-12 md:bottom-10 right-0 px-8 md:px-12 flex items-end z-20 font-sans text-[10px] md:text-xs tracking-widest uppercase text-cream/60">
      <div class="flex flex-col gap-3 pb-2 text-right" data-speed="1.02">
        <a href="https://instagram.com/nastion" target="_blank" rel="noopener" class="hover:text-sunflower transition-colors duration-300">Instagram</a>
        <a href="https://t.me/nastion" target="_blank" rel="noopener" class="hover:text-sunflower transition-colors duration-300">Telegram</a>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 z-20 opacity-70">
      <span class="text-[10px] uppercase tracking-[0.3em] font-sans text-cream/50">Discover</span>
      <div class="w-[1px] h-16 bg-gradient-to-b from-cream/50 to-transparent"></div>
    </div>
  </section>

  <!-- About - Cream with asymmetrical layout -->
  <section class="bg-cream pt-24 pb-20 md:pt-40 md:pb-32 relative overflow-hidden text-ink">
    <!-- Wavy top separator -->
    <div class="absolute top-0 left-0 w-full text-forest">
      <svg viewBox="0 0 1440 120" class="w-full h-[80px] fill-current" preserveAspectRatio="none">
        <path d="M0,64L80,69.3C160,75,320,85,480,80C640,75,800,53,960,48C1120,43,1280,53,1360,58.7L1440,64L1440,0L1360,0C1280,0,1120,0,960,0C800,0,640,0,480,0C320,0,160,0,80,0L0,0Z"></path>
      </svg>
    </div>

    <div class="max-w-5xl mx-auto px-6 relative z-10">
      <div class="grid md:grid-cols-12 gap-8 md:gap-12 items-center">
        <div class="md:col-span-4" data-speed="0.95">
          <p class="text-sm text-terracotta tracking-widest uppercase mb-4 border-b border-terracotta/30 pb-2 inline-block">The Vision</p>
        </div>
        <div class="md:col-span-8 section-fade" style="animation-delay: 0.1s" data-speed="1.05">
          <p class="text-3xl md:text-4xl leading-snug font-serif italic mb-8">
            Creating meaningful digital presence for brands and individuals.
          </p>
          <p class="text-lg md:text-xl text-ink/70 font-sans font-light leading-relaxed">
            Specializing in social media strategy, targeted advertising,
            and lifestyle content that <span class="text-terracotta font-medium italic">connects</span> deeply with modern audiences. A blend of aesthetics and analytics.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services - Sage / Forest organic cards -->
  <section class="bg-sage text-forest py-20 md:py-32 relative">
    <!-- Abstract wavy shape background -->
    <div class="absolute inset-0 opacity-10">
      <svg width="100%" height="100%" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="wavyPattern" x="0" y="0" width="100" height="100" patternUnits="userSpaceOnUse">
            <path d="M0 50 Q 25 25, 50 50 T 100 50" fill="none" stroke="currentColor" stroke-width="1"/>
          </pattern>
        </defs>
        <rect x="0" y="0" width="100%" height="100%" fill="url(#wavyPattern)"/>
      </svg>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="text-center mb-16 md:mb-20">
        <h2 class="text-5xl md:text-6xl font-serif italic text-forest">Expertise</h2>
        <div class="w-24 h-[1px] bg-forest/30 mx-auto mt-6"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-6 md:gap-8">
        {[
          { id: '01', title: 'SMM', desc: 'Strategy, content planning, and authentic community engagement.', color: 'bg-cream' },
          { id: '02', title: 'Targeting', desc: 'Precise audience mapping and high-conversion ad campaigns.', color: 'bg-terracotta text-cream' },
          { id: '03', title: 'Content', desc: 'Photography, aesthetic reels, and cohesive brand storytelling.', color: 'bg-forest text-cream' }
        ].map((service, i) => (
          <div class={`service-card p-8 md:p-10 rounded-[2rem] rounded-tl-none ${service.color} transition-all duration-300 shadow-xl shadow-ink/5 hover:-translate-y-2 hover:shadow-2xl`}>
            <span class="text-sm font-sans tracking-widest opacity-70 mb-8 block">{service.id}</span>
            <h3 class="text-3xl font-serif mb-4">{service.title}</h3>
            <p class="font-sans font-light opacity-90">{service.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Scrolling Marquee - Terracotta -->
  <section class="bg-terracotta text-cream py-8 overflow-hidden relative z-20">
    <div class="flex">
      <div class="animate-marquee flex shrink-0 items-center space-x-8 text-2xl font-serif italic tracking-wider pr-8">
        <span>CONTENT STRATEGY</span>
        <span class="text-sunflower">✦</span>
        <span>BRAND IDENTITY</span>
        <span class="text-sunflower">✦</span>
        <span>TARGETED ADS</span>
        <span class="text-sunflower">✦</span>
        <span>AESTHETIC REELS</span>
        <span class="text-sunflower">✦</span>
        <span>COMMUNITY BUILDING</span>
        <span class="text-sunflower">✦</span>
        <span>CONTENT STRATEGY</span>
        <span class="text-sunflower">✦</span>
        <span>BRAND IDENTITY</span>
        <span class="text-sunflower">✦</span>
        <span>TARGETED ADS</span>
        <span class="text-sunflower">✦</span>
        <span>AESTHETIC REELS</span>
        <span class="text-sunflower">✦</span>
        <span>COMMUNITY BUILDING</span>
        <span class="text-sunflower">✦</span>
      </div>
      <!-- Duplicate for seamless loop -->
      <div class="animate-marquee flex shrink-0 items-center space-x-8 text-2xl font-serif italic tracking-wider pr-8" aria-hidden="true">
        <span>CONTENT STRATEGY</span>
        <span class="text-sunflower">✦</span>
        <span>BRAND IDENTITY</span>
        <span class="text-sunflower">✦</span>
        <span>TARGETED ADS</span>
        <span class="text-sunflower">✦</span>
        <span>AESTHETIC REELS</span>
        <span class="text-sunflower">✦</span>
        <span>COMMUNITY BUILDING</span>
        <span class="text-sunflower">✦</span>
        <span>CONTENT STRATEGY</span>
        <span class="text-sunflower">✦</span>
        <span>BRAND IDENTITY</span>
        <span class="text-sunflower">✦</span>
        <span>TARGETED ADS</span>
        <span class="text-sunflower">✦</span>
        <span>AESTHETIC REELS</span>
        <span class="text-sunflower">✦</span>
        <span>COMMUNITY BUILDING</span>
        <span class="text-sunflower">✦</span>
      </div>
    </div>
  </section>

  <!-- Experience - Cream -->
  <section class="bg-cream pt-24 pb-20 md:pt-40 md:pb-32 relative text-ink">
    <!-- Wavy top separator -->
    <div class="absolute top-0 left-0 w-full text-sage">
      <svg viewBox="0 0 1440 120" class="w-full h-[80px] fill-current" preserveAspectRatio="none">
        <path d="M0,64L80,74.7C160,85,320,107,480,101.3C640,96,800,64,960,58.7C1120,53,1280,75,1360,85.3L1440,96L1440,0L1360,0C1280,0,1120,0,960,0C800,0,640,0,480,0C320,0,160,0,80,0L0,0Z"></path>
      </svg>
    </div>

    <div class="max-w-4xl mx-auto px-6 relative z-10">
      <div data-speed="0.95" class="mb-16 md:mb-20 text-center">
        <h2 class="text-5xl md:text-6xl font-serif italic text-burgundy">Journey</h2>
      </div>
      
      <div class="space-y-8 pl-4 md:pl-0 border-l border-terracotta/20 md:border-none relative">
        <div data-speed="1.02">
          <div class="relative md:flex gap-12 items-start tilt-card p-6 md:p-8 rounded-[2rem] hover:bg-white/40 transition-all duration-300 border border-transparent hover:border-white/60 shadow-none hover:shadow-xl" style="transform-style: preserve-3d;">
            <div class="hidden md:block w-1/4 text-right pt-2" style="transform: translateZ(20px);">
              <p class="text-sm text-terracotta font-medium tracking-widest">2023 — Present</p>
            </div>
            <div class="absolute -left-[5px] md:static w-3 h-3 rounded-full bg-terracotta mt-2 shrink-0 md:mt-3 shadow-[0_0_0_4px_rgba(198,125,94,0.2)]" style="transform: translateZ(30px);"></div>
            <div class="md:w-3/4 pl-6 md:pl-0" style="transform: translateZ(40px);">
              <p class="text-sm text-terracotta font-medium tracking-widest md:hidden mb-2">2023 — Present</p>
              <h3 class="text-2xl font-serif mb-3">Freelance SMM & Content Creator</h3>
              <p class="text-ink/70 font-light font-sans">Working with lifestyle brands, personal brands, and small businesses to elevate their digital footprint through organic aesthetics.</p>
            </div>
          </div>
        </div>

        <div data-speed="1.05">
          <div class="relative md:flex gap-12 items-start tilt-card p-6 md:p-8 rounded-[2rem] hover:bg-white/40 transition-all duration-300 border border-transparent hover:border-white/60 shadow-none hover:shadow-xl" style="transform-style: preserve-3d;">
            <div class="hidden md:block w-1/4 text-right pt-2" style="transform: translateZ(20px);">
              <p class="text-sm text-sage font-medium tracking-widest">2022 — 2023</p>
            </div>
            <div class="absolute -left-[5px] md:static w-3 h-3 rounded-full bg-sage mt-2 shrink-0 md:mt-3 shadow-[0_0_0_4px_rgba(125,155,132,0.2)]" style="transform: translateZ(30px);"></div>
            <div class="md:w-3/4 pl-6 md:pl-0" style="transform: translateZ(40px);">
              <p class="text-sm text-sage font-medium tracking-widest md:hidden mb-2">2022 — 2023</p>
              <h3 class="text-2xl font-serif mb-3">Social Media Manager</h3>
              <p class="text-ink/70 font-light font-sans">Brand collaboration, campaign management, and establishing visual identity for emerging labels.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact - Burgundy with dramatic typography -->
  <section class="bg-burgundy text-cream py-20 md:py-32 relative overflow-hidden">
    <!-- 3D Canvas for contact section -->
    <canvas id="contact-3d-canvas" class="absolute inset-0 w-full h-full pointer-events-none z-0"></canvas>

    <div data-speed="0.8" class="absolute -top-40 -right-40 w-96 h-96 bg-terracotta/20 rounded-full blur-3xl"></div>
    <div data-speed="1.2" class="absolute -bottom-20 -left-20 w-80 h-80 bg-forest/30 rounded-full blur-3xl"></div>

    <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
      <div data-speed="1.05">
        <p class="text-sm text-sunflower tracking-widest uppercase mb-6 font-sans">Співпраця</p>
        <h2 class="text-5xl md:text-7xl font-serif italic mb-8">Let's Create Magic</h2>
        <p class="text-cream/80 mb-16 max-w-lg mx-auto font-sans font-light text-lg">
          Open to collaborations, brand partnerships, and new creative projects that push boundaries.
        </p>
        
        <div class="flex flex-wrap justify-center gap-6 font-sans">
          <a href="https://instagram.com/nastion" target="_blank" rel="noopener"
             class="magnetic group relative w-full md:w-auto px-8 py-4 bg-cream text-burgundy rounded-full overflow-hidden block md:inline-block">
            <span class="relative z-10 font-medium tracking-wide">Instagram</span>
            <div class="absolute inset-0 h-full w-full bg-sunflower scale-x-0 group-hover:scale-x-100 transition-transform origin-left ease-out duration-300"></div>
          </a>
          <a href="mailto:hello@anastasia.com"
             class="magnetic group relative w-full md:w-auto px-8 py-4 border border-cream/30 rounded-full overflow-hidden block md:inline-block">
             <span class="relative z-10 text-cream group-hover:text-ink transition-colors duration-300 tracking-wide">Email</span>
             <div class="absolute inset-0 h-full w-full bg-cream scale-x-0 group-hover:scale-x-100 transition-transform origin-left ease-out duration-300"></div>
          </a>
          <a href="https://t.me/nastion" target="_blank" rel="noopener"
             class="magnetic group relative w-full md:w-auto px-8 py-4 border border-cream/30 rounded-full overflow-hidden block md:inline-block">
             <span class="relative z-10 text-cream group-hover:text-ink transition-colors duration-300 tracking-wide">Telegram</span>
             <div class="absolute inset-0 h-full w-full bg-cream scale-x-0 group-hover:scale-x-100 transition-transform origin-left ease-out duration-300"></div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-ink text-cream/40 pt-10 pb-[calc(2.5rem+env(safe-area-inset-bottom))]">
    <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center text-sm font-sans gap-4">
      <p class="tracking-widest uppercase text-xs">© 2026 Anastasia. All rights reserved.</p>
      <svg class="w-8 h-10 text-sage opacity-50" viewBox="0 0 40 48" xmlns="http://www.w3.org/2000/svg">
        <path d="M4 46 C4 20, 20 4, 20 4 C20 4, 36 20, 36 46" stroke="currentColor" stroke-width="1.5" fill="none"/>
      </svg>
      <p class="tracking-widest uppercase text-xs hidden md:block">Designed with Intention</p>
    </div>
  </footer>

  <script>
    import * as THREE from 'three';

    const canvas = document.getElementById('hero-3d-canvas');
    if (canvas) {
      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(90, window.innerWidth / window.innerHeight, 0.1, 1000);
      const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.setSize(window.innerWidth, window.innerHeight);

      // Shift camera to the right so shapes appear more on right side
      camera.position.x = -3;

      // Lighting
      const ambientLight = new THREE.AmbientLight(0xffffff, 1.2);
      scene.add(ambientLight);
      
      const directionalLight = new THREE.DirectionalLight(0xffffff, 2);
      directionalLight.position.set(5, 10, 5);
      scene.add(directionalLight);

      // Shapes replacing rubber balloons
      const objects = [];

      // Reusable Materials
      const matTerracotta = new THREE.MeshStandardMaterial({
        color: 0xC67D5E,
        roughness: 0.1,
        metalness: 0.3,
        flatShading: true
      });
      const matSunflower = new THREE.MeshStandardMaterial({
        color: 0xE1A95F,
        roughness: 0.4,
        metalness: 0.8,
        wireframe: true,
        transparent: true,
        opacity: 0.4
      });
      const matSage = new THREE.MeshStandardMaterial({
        color: 0x7D9B84,
        roughness: 0.2,
        metalness: 0.1
      });

      // 1. Large Terracotta Crystal (hero piece, right side)
      const geoCryst1 = new THREE.IcosahedronGeometry(3, 0);
      const meshCryst1 = new THREE.Mesh(geoCryst1, matTerracotta);
      meshCryst1.position.set(8, 1, -8);
      scene.add(meshCryst1);
      objects.push({ mesh: meshCryst1, rx: 0.004, ry: 0.006, bx: 8, by: 1, offset: 0 });

      // 2. Medium Terracotta Crystal (top edge, partially visible)
      const geoCryst2 = new THREE.IcosahedronGeometry(2, 0);
      const meshCryst2 = new THREE.Mesh(geoCryst2, matTerracotta);
      meshCryst2.position.set(12, 7, -12);
      scene.add(meshCryst2);
      objects.push({ mesh: meshCryst2, rx: 0.008, ry: 0.01, bx: 12, by: 7, offset: 2 });

      // 3. Main Sunflower Knot (center-right, large)
      const geoKnot1 = new THREE.TorusKnotGeometry(3.5, 0.7, 100, 16);
      const meshKnot1 = new THREE.Mesh(geoKnot1, matSunflower);
      meshKnot1.position.set(5, -3, -14);
      scene.add(meshKnot1);
      objects.push({ mesh: meshKnot1, rx: 0.002, ry: 0.004, bx: 5, by: -3, offset: Math.PI });

      // 4. Small Sunflower Knot (bottom edge)
      const geoKnot2 = new THREE.TorusKnotGeometry(1.5, 0.4, 64, 12);
      const meshKnot2 = new THREE.Mesh(geoKnot2, matSunflower);
      meshKnot2.position.set(10, -6, -10);
      scene.add(meshKnot2);
      objects.push({ mesh: meshKnot2, rx: 0.005, ry: 0.003, bx: 10, by: -6, offset: 1.5 });

      // 5. Large Sage Ring (top right, dramatic)
      const geoRing1 = new THREE.TorusGeometry(2.5, 0.6, 16, 50);
      const meshRing1 = new THREE.Mesh(geoRing1, matSage);
      meshRing1.position.set(6, 5, -10);
      scene.add(meshRing1);
      objects.push({ mesh: meshRing1, rx: 0.006, ry: 0.002, bx: 6, by: 5, offset: Math.PI / 2 });

      // 6. Medium Sage Ring (floating mid-right)
      const geoRing2 = new THREE.TorusGeometry(1.8, 0.4, 16, 50);
      const meshRing2 = new THREE.Mesh(geoRing2, matSage);
      meshRing2.position.set(11, 0, -16);
      scene.add(meshRing2);
      objects.push({ mesh: meshRing2, rx: 0.003, ry: 0.005, bx: 11, by: 0, offset: 4 });

      // 7. Giant Sage Ring (deep background, spanning)
      const geoRing3 = new THREE.TorusGeometry(5, 0.3, 16, 50);
      const meshRing3 = new THREE.Mesh(geoRing3, matSage);
      meshRing3.position.set(4, 0, -25);
      scene.add(meshRing3);
      objects.push({ mesh: meshRing3, rx: 0.001, ry: 0.002, bx: 4, by: 0, offset: 5 });

      // 8. Tiny Terracotta Crystal (accent, near edge)
      const geoCryst3 = new THREE.IcosahedronGeometry(1, 0);
      const meshCryst3 = new THREE.Mesh(geoCryst3, matTerracotta);
      meshCryst3.position.set(13, -2, -9);
      scene.add(meshCryst3);
      objects.push({ mesh: meshCryst3, rx: 0.012, ry: 0.008, bx: 13, by: -2, offset: 3 });

      // 9. Extra small crystal (top accent)
      const geoCryst4 = new THREE.IcosahedronGeometry(0.7, 0);
      const meshCryst4 = new THREE.Mesh(geoCryst4, matTerracotta);
      meshCryst4.position.set(3, 6, -11);
      scene.add(meshCryst4);
      objects.push({ mesh: meshCryst4, rx: 0.015, ry: 0.012, bx: 3, by: 6, offset: 1 });

      // 10. Tiny sage ring (floating accent)
      const geoRing4 = new THREE.TorusGeometry(0.8, 0.25, 16, 32);
      const meshRing4 = new THREE.Mesh(geoRing4, matSage);
      meshRing4.position.set(9, 3, -13);
      scene.add(meshRing4);
      objects.push({ mesh: meshRing4, rx: 0.01, ry: 0.008, bx: 9, by: 3, offset: 2.5 });

      camera.position.z = 5;

      // Mouse parallax
      let mouseX = 0;
      let mouseY = 0;
      let targetX = 0;
      let targetY = 0;

      const windowHalfX = window.innerWidth / 2;
      const windowHalfY = window.innerHeight / 2;

      document.addEventListener('mousemove', (event) => {
        mouseX = (event.clientX - windowHalfX) * 0.002;
        mouseY = (event.clientY - windowHalfY) * 0.002;
      });

      // Text zone boundary (left side where text lives)
      const textZoneBoundary = 1;
      const repulsionStrength = 0.2;

      const clock = new THREE.Clock();

      function animate() {
        requestAnimationFrame(animate);

        const elapsedTime = clock.getElapsedTime();

        targetX = mouseX * 2;
        targetY = mouseY * 2;

        objects.forEach(obj => {
          // Spin
          obj.mesh.rotation.x += obj.rx;
          obj.mesh.rotation.y += obj.ry;

          // Float up and down
          const floatY = Math.sin(elapsedTime * 0.5 + obj.offset) * 0.5;

          // Calculate target position
          let newX = obj.bx + targetX;
          let newY = obj.by - targetY + floatY;

          // Repulsion from text zone (bounce off left side)
          if (newX < textZoneBoundary) {
            const penetration = textZoneBoundary - newX;
            newX = textZoneBoundary + penetration * repulsionStrength;
            // Add some wobble when bouncing
            obj.mesh.rotation.z += 0.02;
          }

          // Also keep shapes from going too far right
          const rightBoundary = 16;
          if (newX > rightBoundary) {
            newX = rightBoundary;
          }

          // Smooth follow with bounce effect
          const dx = newX - obj.mesh.position.x;
          const dy = newY - obj.mesh.position.y;

          obj.mesh.position.x += dx * 0.04;
          obj.mesh.position.y += dy * 0.04;
        });

        renderer.render(scene, camera);
      }

      animate();

      window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
      });
    }

    // Contact Section 3D Scene
    const contactCanvas = document.getElementById('contact-3d-canvas');
    if (contactCanvas) {
      const scene2 = new THREE.Scene();
      const camera2 = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
      const renderer2 = new THREE.WebGLRenderer({ canvas: contactCanvas, alpha: true, antialias: true });
      renderer2.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer2.setSize(window.innerWidth, window.innerHeight);

      const ambientLight2 = new THREE.AmbientLight(0xffffff, 0.8);
      scene2.add(ambientLight2);

      const directionalLight2 = new THREE.DirectionalLight(0xffffff, 1.5);
      directionalLight2.position.set(5, 10, 5);
      scene2.add(directionalLight2);

      // Materials for contact section (cream/gold tones)
      const matCream = new THREE.MeshStandardMaterial({
        color: 0xF5F2ED,
        roughness: 0.2,
        metalness: 0.1,
        transparent: true,
        opacity: 0.6
      });
      const matGold = new THREE.MeshStandardMaterial({
        color: 0xE1A95F,
        roughness: 0.3,
        metalness: 0.7,
        wireframe: true,
        transparent: true,
        opacity: 0.4
      });

      const contactObjects = [];

      // Floating cream torus (left)
      const geoT1 = new THREE.TorusGeometry(1.5, 0.4, 16, 50);
      const meshT1 = new THREE.Mesh(geoT1, matCream);
      meshT1.position.set(-8, 2, -10);
      scene2.add(meshT1);
      contactObjects.push({ mesh: meshT1, rx: 0.005, ry: 0.008, bx: -8, by: 2, offset: 0 });

      // Gold wireframe knot (right)
      const geoK1 = new THREE.TorusKnotGeometry(2, 0.5, 80, 12);
      const meshK1 = new THREE.Mesh(geoK1, matGold);
      meshK1.position.set(9, -1, -12);
      scene2.add(meshK1);
      contactObjects.push({ mesh: meshK1, rx: 0.003, ry: 0.004, bx: 9, by: -1, offset: Math.PI });

      // Small cream icosahedron (top right)
      const geoI1 = new THREE.IcosahedronGeometry(1, 0);
      const meshI1 = new THREE.Mesh(geoI1, matCream);
      meshI1.position.set(7, 4, -8);
      scene2.add(meshI1);
      contactObjects.push({ mesh: meshI1, rx: 0.008, ry: 0.006, bx: 7, by: 4, offset: 2 });

      // Gold ring (bottom left)
      const geoR1 = new THREE.TorusGeometry(2, 0.3, 16, 50);
      const meshR1 = new THREE.Mesh(geoR1, matGold);
      meshR1.position.set(-6, -3, -14);
      scene2.add(meshR1);
      contactObjects.push({ mesh: meshR1, rx: 0.004, ry: 0.007, bx: -6, by: -3, offset: 1.5 });

      camera2.position.z = 5;

      const clock2 = new THREE.Clock();

      function animateContact() {
        requestAnimationFrame(animateContact);
        const elapsedTime = clock2.getElapsedTime();

        contactObjects.forEach(obj => {
          obj.mesh.rotation.x += obj.rx;
          obj.mesh.rotation.y += obj.ry;
          const floatY = Math.sin(elapsedTime * 0.4 + obj.offset) * 0.3;
          obj.mesh.position.y = obj.by + floatY;
        });

        renderer2.render(scene2, camera2);
      }

      animateContact();

      window.addEventListener('resize', () => {
        camera2.aspect = window.innerWidth / window.innerHeight;
        camera2.updateProjectionMatrix();
        renderer2.setSize(window.innerWidth, window.innerHeight);
      });
    }

    // Tilt effect for service cards (desktop only)
    const isMobile = window.matchMedia("(max-width: 768px)").matches;
    if (!isMobile) {
      const tiltCards = document.querySelectorAll('[data-tilt]');
      tiltCards.forEach(card => {
        let currentX = 0;
        let currentY = 0;
        let targetX = 0;
        let targetY = 0;

        card.addEventListener('mouseenter', () => {
          card.style.transition = 'none';
        });

        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          const centerX = rect.width / 2;
          const centerY = rect.height / 2;
          targetX = (y - centerY) / 15;
          targetY = (centerX - x) / 15;

          currentX += (targetX - currentX) * 0.1;
          currentY += (targetY - currentY) * 0.1;

          card.style.transform = `perspective(1000px) rotateX(${currentX}deg) rotateY(${currentY}deg) scale(1.02)`;
        });

        card.addEventListener('mouseleave', () => {
          card.style.transition = 'transform 0.5s ease-out';
          card.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) scale(1)';
        });
      });
    }
  </script>
</Layout>

