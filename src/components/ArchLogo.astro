---
interface Props {
  class?: string;
  size?: number;
}

const { class: className = "", size = 48 } = Astro.props;
---

<svg
  class:list={["arch-logo", className]}
  width={size * 0.83}
  height={size}
  viewBox="0 0 40 48"
  xmlns="http://www.w3.org/2000/svg"
>
  <path d="M4 46 C4 20, 20 4, 20 4 C20 4, 36 20, 36 46" />
</svg>
